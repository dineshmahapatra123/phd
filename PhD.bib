@techreport{kapoor2024,
  type = {Working {{Paper}}},
  title = {Land Record Management in {{India}}},
  author = {Kapoor, Amit and Esposito, Mark and Anand, Mukul},
  year = 2024,
  institution = {Social Science Research Network},
  urldate = {2026-01-03},
  abstract = {Land administration, also referred to as land record management, is a complex and vital process overseeing the ownership, use, and value of land. It serves as the intricate map and compass guiding our interactions with this fundamental resource, ensuring fairness and smooth operations. The key aspects of land administration encompass determining and recording land rights, involving the identification of landowners, delineation of ownership extents, and documentation of encumbrances through vital processes like land surveying. Maintaining land records plays a crucial role, acting as the official narrative of a piece of land, chronicling its ownership history, value, and legal documents, typically stored in centralised databases and made accessible to the public. The meticulous recording of land transfers serves pivotal roles in ensuring individual rights and societal well-being. It establishes certainty of ownership, protects landowners from fraud, and supports confident investment and land use.},
  langid = {english},
  keywords = {blockchain,distributed ledger technologies,DLT,India,land administration,Land record management,land rights},
  file = {/Users/dineshmahapatra/Zotero/storage/ELEXWTK6/Kapoor et al. - 2024 - Land Record Management in India.pdf}
}

@article{kapur2020,
  title = {Why {{Does}} the {{Indian State Both Fail}} and {{Succeed}}?},
  author = {Kapur, Devesh},
  year = 2020,
  journal = {The Journal of Economic Perspectives},
  volume = {34},
  number = {1},
  eprint = {26873528},
  eprinttype = {jstor},
  pages = {31--54},
  publisher = {American Economic Association},
  issn = {0895-3309},
  urldate = {2026-04-08},
  abstract = {The Indian state's performance spans the spectrum from woefully inadequate, especially in core public goods provision, to surprisingly impressive in successfully managing complex tasks and on a massive scale. It has delivered better on macroeconomic rather than microeconomic outcomes, where delivery is episodic with inbuilt exit than where delivery and accountability are quotidian and more reliant on state capacity at local levels, and on those goods and services where societal norms on hierarchy and status matter less than where they are resilient. The paper highlights three reasons for these outcomes: under-resourced local governments, the long-term effects of India's "precocious" democracy, and the persistence of social cleavage. However, claims that India's state is bloated in size and submerged in patronage have weak basis. The paper concludes by highlighting a reversal of past trends in that state capacity is improving at the micro level even as India's macro performance has become more worrisome.},
  file = {/Users/dineshmahapatra/Zotero/storage/XWL2MVVR/Kapur - 2020 - Why Does the Indian State Both Fail and Succeed.pdf}
}

